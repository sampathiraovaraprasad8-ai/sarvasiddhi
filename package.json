{
  "name": "sarvasiddhi-pooja-store",
  "version": "1.0.0",
  "description": "E-commerce platform for Sarvasiddhi Pooja Samagri store",
  "main": "server.js",
  "scripts": {
    "install-all": "npm install && npm run install-frontend",
    "install-frontend": "npm install --prefix sarvasiddhi",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix sarvasiddhi",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix sarvasiddhi",
    "start": "node server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.5.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
